{
  "manifest_version": 3,
  "name": "EpochExt",
  "version": "1.3.2",
  "description": "Hover over an epoch-timestamp anywhere on the web to see it as a human-readable date in your chosen timezone (default Eastern EDT/EST).",
  "permissions": ["storage"],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "EpochExt settings",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "css": ["tooltip.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
